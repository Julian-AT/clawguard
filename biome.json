{
  "$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "overrides": [
    {
      "includes": ["components/report/mermaid-diagram.tsx"],
      "linter": {
        "rules": {
          "security": {
            "noDangerouslySetInnerHtml": "off"
          }
        }
      }
    },
    {
      "includes": ["tests/components/report-shell.ssr.test.ts"],
      "linter": {
        "rules": {
          "correctness": {
            "noChildrenProp": "off"
          }
        }
      }
    },
    {
      "includes": ["components/ui/sidebar.tsx"],
      "linter": {
        "rules": {
          "suspicious": {
            "noDocumentCookie": "off"
          },
          "correctness": {
            "useExhaustiveDependencies": "off"
          }
        }
      }
    },
    {
      "includes": [
        "lib/landing-config.tsx",
        "components/landing-icons.tsx",
        "components/github-mark-icon.tsx",
        "components/third-bento-animation.tsx"
      ],
      "linter": {
        "rules": {
          "a11y": {
            "noSvgWithoutTitle": "off"
          }
        }
      }
    },
    {
      "includes": ["components/fourth-bento-animation.tsx"],
      "linter": {
        "rules": {
          "a11y": {
            "noStaticElementInteractions": "off"
          },
          "suspicious": {
            "noArrayIndexKey": "off"
          }
        }
      }
    },
    {
      "includes": [
        "components/first-bento-animation.tsx",
        "components/sections/quote-section.tsx",
        "components/ui/feature-slideshow.tsx",
        "components/ui/hero-video-dialog.tsx"
      ],
      "linter": {
        "rules": {
          "performance": {
            "noImgElement": "off"
          },
          "a11y": {
            "noStaticElementInteractions": "off",
            "useKeyWithClickEvents": "off",
            "useValidAnchor": "off",
            "useIframeTitle": "off"
          },
          "correctness": {
            "useExhaustiveDependencies": "off"
          }
        }
      }
    },
    {
      "includes": [
        "components/ui/breadcrumb.tsx",
        "components/ui/chart.tsx",
        "components/ui/code-block.tsx",
        "components/ui/field.tsx",
        "components/ui/marquee.tsx",
        "components/ui/orbiting-circle.tsx",
        "components/ui/response-stream.tsx",
        "components/ui/markdown.tsx",
        "components/sections/faq-section.tsx"
      ],
      "linter": {
        "rules": {
          "a11y": {
            "useFocusableInteractive": "off",
            "useSemanticElements": "off"
          },
          "security": {
            "noDangerouslySetInnerHtml": "off"
          },
          "suspicious": {
            "noArrayIndexKey": "off"
          }
        }
      }
    }
  ]
}
