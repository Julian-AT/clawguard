# GitHub App (for Chat SDK GitHub Adapter)
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_BOT_USERNAME=clawguard

# GitHub Token (for Octokit direct API calls and Sandbox git clone)
GITHUB_TOKEN=

# Vercel KV (Upstash-backed, HTTP REST — for audit data storage)
# Run `vercel env pull` after linking project and adding KV store
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Redis (TCP — for Chat SDK state adapter)
REDIS_URL=

# NextAuth (dashboard GitHub OAuth)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Public URL for absolute report links in GitHub comments (production: https://your-app.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: GitHub App install/settings link on dashboard CTA
NEXT_PUBLIC_GITHUB_APP_URL=
